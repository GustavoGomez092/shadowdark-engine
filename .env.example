# Peer-to-peer TURN/ICE configuration (cross-network connectivity).
# All optional — if unset, PeerJS uses its own default STUN/TURN servers.

# Recommended: a credential endpoint (e.g. the Cloudflare Worker in
# cloudflare-turn-worker/) that returns { "iceServers": [...] }.
# VITE_ICE_SERVERS_URL=https://shadowdark-turn.your-account.workers.dev

# Alternative: static TURN credentials baked into the build (expire per TTL).
# VITE_TURN_URLS=turns:turn.example.com:443?transport=tcp,turn:turn.example.com:3478
# VITE_TURN_USERNAME=your-username
# VITE_TURN_CREDENTIAL=your-credential
