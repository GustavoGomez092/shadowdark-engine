  "aboleth": {
    "name": "Aboleth",
    "description": "Un antiguo horror acuático con dominio psíquico sobre mentes inferiores.",
    "attacks": {
      "Tentacle": "Tentáculo",
      "Tail": "Cola"
    },
    "abilities": {
      "Curse": {
        "name": "Maldición",
        "description": "Una criatura golpeada por un tentáculo debe pasar DC 15 CON o contraer una enfermedad mucosa. En 1d4 horas solo podrá respirar bajo el agua."
      },
      "Enslave": {
        "name": "Esclavizar",
        "description": "El aboleth selecciona una criatura dentro de rango near. DC 15 WIS o encantado por 1 día. Puede repetir la tirada de salvación cuando recibe daño."
      },
      "Telepathic": {
        "name": "Telepático",
        "description": "El aboleth se comunica telepáticamente con cualquier criatura dentro de rango far."
      }
    }
  },
  "acolyte": {
    "name": "Acólito",
    "description": "Un sacerdote de bajo rango devoto a una deidad.",
    "attacks": {
      "Mace": "Maza",
      "Spell": "Conjuro"
    },
    "abilities": {
      "Healing Touch": {
        "name": "Toque Sanador",
        "description": "Una vez al día, el acólito puede curar a una criatura dentro de rango close por 1d4 HP."
      }
    }
  },
  "animated-armor": {
    "name": "Armadura Animada",
    "description": "Una armadura de placas animada por magia arcana para custodiar un lugar.",
    "attacks": {
      "Longsword": "Espada Larga"
    },
    "abilities": {
      "Statue": {
        "name": "Estatua",
        "description": "La armadura animada parece una armadura normal cuando está inmóvil. Es indistinguible hasta que se mueve."
      }
    }
  },
  "bandit": {
    "name": "Bandido",
    "description": "Un forajido común que acecha a los viajeros.",
    "attacks": {
      "Club": "Garrote",
      "Shortbow": "Arco Corto"
    },
    "abilities": {
      "Ambush": {
        "name": "Emboscada",
        "description": "Si el bandido sorprende a un objetivo, inflige 1d6 de daño adicional en su primer ataque."
      }
    }
  },
  "bat-giant": {
    "name": "Murciélago Gigante",
    "description": "Un murciélago del tamaño de un perro con una mordida feroz.",
    "attacks": {
      "Bite": "Mordida"
    },
    "abilities": {}
  },
  "bear-brown": {
    "name": "Oso Pardo",
    "description": "Un oso enorme y poderoso que defiende su territorio con ferocidad.",
    "attacks": {
      "Claw": "Garra"
    },
    "abilities": {
      "Crush": {
        "name": "Aplastar",
        "description": "Si ambos ataques de garra golpean al mismo objetivo, el oso lo aplasta por 1d8 de daño adicional."
      }
    }
  },
  "beastman": {
    "name": "Hombre Bestia",
    "description": "Un humanoide salvaje con cabeza de cabra que saquea y arrasa.",
    "attacks": {
      "Spear": "Lanza"
    },
    "abilities": {
      "Brutal": {
        "name": "Brutal",
        "description": "+1 de daño en ataques cuerpo a cuerpo (ya incluido en el daño)."
      }
    }
  },
  "boar": {
    "name": "Jabalí",
    "description": "Un cerdo salvaje con colmillos afilados y mal temperamento.",
    "attacks": {
      "Tusk": "Colmillo"
    },
    "abilities": {
      "Gore": {
        "name": "Embestida",
        "description": "Si el jabalí se mueve todo su movimiento en línea recta y golpea con un ataque de colmillo, el objetivo recibe 1d6 de daño adicional."
      }
    }
  },
  "cave-brute": {
    "name": "Bruto de las Cavernas",
    "description": "Un depredador subterráneo corpulento con garras poderosas y mandíbulas aplastantes.",
    "attacks": {
      "Claw": "Garra",
      "Mandible": "Mandíbula"
    },
    "abilities": {
      "Bewilder": {
        "name": "Aturdir",
        "description": "Una vez por ronda, una criatura golpeada por una garra debe pasar DC 12 WIS o quedar aturdida por 1 ronda (desventaja en ataques)."
      }
    }
  },
  "cave-creeper": {
    "name": "Reptador de las Cavernas",
    "description": "Un artrópodo de muchas patas que acecha en los techos de las cavernas.",
    "attacks": {
      "Bite": "Mordida",
      "Tentacles": "Tentáculos"
    },
    "abilities": {
      "Toxin": {
        "name": "Toxina",
        "description": "Una criatura golpeada por los tentáculos debe pasar DC 12 CON o quedar paralizada por 1d4 rondas."
      }
    }
  },
  "crocodile": {
    "name": "Cocodrilo",
    "description": "Un reptil grande y acorazado que embosca presas cerca del agua.",
    "attacks": {
      "Bite": "Mordida"
    },
    "abilities": {}
  },
  "cultist": {
    "name": "Cultista",
    "description": "Un seguidor fanático de un poder oscuro.",
    "attacks": {
      "Longsword": "Espada Larga",
      "Spell": "Conjuro"
    },
    "abilities": {
      "Fearless": {
        "name": "Intrépido",
        "description": "El cultista nunca realiza chequeos de moral."
      },
      "Deathtouch": {
        "name": "Toque Mortal",
        "description": "Una vez al día, el cultista puede hacer un ataque de conjuro cuerpo a cuerpo (+2). Si golpea, el objetivo recibe 2d6 de daño necrótico."
      }
    }
  },
  "darkmantle": {
    "name": "Manto Oscuro",
    "description": "Una criatura similar a un murciélago que envuelve a sus presas en oscuridad mágica.",
    "attacks": {
      "Bite": "Mordida"
    },
    "abilities": {
      "Darkness": {
        "name": "Oscuridad",
        "description": "El manto oscuro puede lanzar oscuridad mágica en un radio near alrededor de sí mismo una vez al día. La oscuridad dura 10 rondas."
      }
    }
  },
  "dragon-swamp": {
    "name": "Dragón de Pantano",
    "description": "Un dragón astuto que habita en ciénagas fétidas, exhalando nubes de smog asfixiante.",
    "attacks": {
      "Rend": "Desgarrar"
    },
    "abilities": {
      "Smog Breath": {
        "name": "Aliento de Smog",
        "description": "El dragón exhala una nube de smog venenoso en un cono de tamaño near. Todas las criaturas en el área deben pasar DC 15 CON o recibir 4d8 de daño de veneno y quedar cegadas por 1d4 rondas. Con éxito, la mitad de daño y no cegadas. Se recarga con 5-6 en 1d6 cada ronda."
      }
    }
  },
  "dryad": {
    "name": "Dríade",
    "description": "Un tímido espíritu del bosque vinculado a un gran árbol.",
    "attacks": {
      "Staff": "Bastón"
    },
    "abilities": {
      "Charm": {
        "name": "Encantar",
        "description": "La dríade selecciona una criatura dentro de rango near. DC 15 WIS o la criatura queda encantada por 1 día y considera a la dríade como un aliado de confianza."
      },
      "Meld": {
        "name": "Fusión",
        "description": "La dríade puede fusionarse con cualquier árbol, volviéndose invisible e inalcanzable. Puede emerger del mismo o de cualquier árbol conectado dentro de rango far."
      }
    }
  },
  "dung-beetle-giant": {
    "name": "Escarabajo Pelotero Gigante",
    "description": "Un escarabajo sobredimensionado que empuja bolas de inmundicia por los túneles subterráneos.",
    "attacks": {
      "Horn": "Cuerno"
    },
    "abilities": {
      "Knock": {
        "name": "Derribar",
        "description": "Si golpea, el objetivo debe pasar DC 12 STR o ser derribado."
      }
    }
  },
  "ettercap": {
    "name": "Ettercap",
    "description": "Un humanoide arácnido que teje redes pegajosas y venenosas.",
    "attacks": {
      "Bite": "Mordida",
      "Poison Web": "Red Venenosa"
    },
    "abilities": {
      "Poison Web": {
        "name": "Red Venenosa",
        "description": "En lugar de morder, el ettercap puede lanzar una red a un objetivo dentro de rango near. DC 12 DEX o el objetivo queda apresado. Un objetivo apresado también debe pasar DC 12 CON o quedar envenenado por 1d4 rondas."
      }
    }
  },
  "fairy": {
    "name": "Hada",
    "description": "Un diminuto embaucador alado armado con una aguja soporífera.",
    "attacks": {
      "Needle": "Aguja"
    },
    "abilities": {
      "Poison": {
        "name": "Veneno",
        "description": "Una criatura golpeada por la aguja del hada debe pasar DC 12 CON o caer en un sueño profundo y mágico por 1d4 horas."
      }
    }
  },
  "gelatinous-cube": {
    "name": "Cubo Gelatinoso",
    "description": "Un cieno casi transparente que llena pasillos enteros, disolviendo todo lo que engulle.",
    "attacks": {
      "Touch": "Toque"
    },
    "abilities": {
      "Engulf": {
        "name": "Engullir",
        "description": "El cubo se mueve al espacio de una criatura. La criatura debe pasar DC 12 DEX o ser engullida. Las criaturas engullidas quedan cegadas, apresadas y reciben 2d6 de daño de ácido al inicio de cada uno de sus turnos."
      },
      "Rubbery": {
        "name": "Elástico",
        "description": "El cubo recibe la mitad de daño de ataques contundentes."
      },
      "Toxin": {
        "name": "Toxina",
        "description": "Una criatura golpeada por el cubo debe pasar DC 12 CON o quedar paralizada por 1d4 rondas."
      }
    }
  },
  "ghost": {
    "name": "Fantasma",
    "description": "Un espíritu atormentado atado al mundo mortal por asuntos pendientes.",
    "attacks": {
      "Death Touch": "Toque Mortal"
    },
    "abilities": {
      "Greater Undead": {
        "name": "No Muerto Superior",
        "description": "El fantasma es inmune a chequeos de moral, sueño, encantamiento y efectos de miedo."
      },
      "Incorporeal": {
        "name": "Incorpóreo",
        "description": "El fantasma puede moverse a través de objetos sólidos y criaturas. Las armas no mágicas lo atraviesan sin causar daño."
      },
      "Life Drain": {
        "name": "Drenar Vida",
        "description": "Una criatura reducida a 0 HP por el toque mortal del fantasma no puede ser curada hasta que un sacerdote lance un conjuro de nivel 2+ sobre ella."
      },
      "Possess": {
        "name": "Poseer",
        "description": "El fantasma selecciona una criatura dentro de rango near. DC 15 CHA o el fantasma toma control del cuerpo del objetivo por hasta 1 hora. El cuerpo del fantasma desaparece. El huésped puede repetir la tirada de salvación cada ronda cuando recibe daño."
      }
    }
  },
